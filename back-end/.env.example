HOST=
PORT=

# App (Prisma + adapter pg): Supavisor transaction, porta 6543 — obrigatório ?pgbouncer=true
# Senhas com &, @, # etc. devem ser URL-encoded na URL (ex.: & → %26)
DATABASE_URL=

# prisma migrate / db push: Supavisor session, porta 5432 (sem pgbouncer=true). Se vazio, cai no DATABASE_URL.
DIRECT_URL=

JWT_SECRET=

# Stripe - obtenha em https://dashboard.stripe.com/apikeys e https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
FRONTEND_URL=